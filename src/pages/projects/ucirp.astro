---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'UCIRP',
};
---

<Layout metadata={metadata}>
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden -mt-[80px] pt-[80px]">
    <video 
      src="/portfolio/vtf_background.mp4" 
      autoplay loop muted playsinline 
      class="absolute top-0 left-0 min-w-full min-h-full w-auto h-auto object-cover object-center -z-10"
    ></video>
    <div class="absolute inset-0 bg-black/60 -z-10"></div>
    
    <h1 class="text-5xl md:text-7xl font-bold text-white tracking-wide text-center font-heading drop-shadow-lg px-4">
      UCI Rocket Project
    </h1>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16 flex flex-col md:flex-row items-center gap-10">
    <div class="flex-1">
      <h2 class="text-3xl font-bold mb-4 font-heading">My Role</h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        I'm currently one of the Chief Engineers and Test Director for the project, where I have ownership over the propulsion system from a system level. I was previously the Lead Propulsion Engineer and Test Lead, where I owned engine design and manufacturing, particularly as it pertains to the nozzle and injector.
      </p>
    </div>

    <div class="flex-shrink-0">
      <a href="https://rocket.eng.uci.edu" target="_blank" class="block hover:scale-105 transition duration-300" aria-label="UCI Rocket Project Website">
        
        <img 
          src="/portfolio/ucirp_logo_dark.svg" 
          alt="UCI Rocket Project Logo" 
          class="w-40 h-40 object-contain rounded-xl shadow-md border border-gray-200 block dark:hidden" 
        />
        
        <img 
          src="/portfolio/ucirp_logo_light.svg" 
          alt="UCI Rocket Project Logo" 
          class="w-40 h-40 object-contain rounded-xl shadow-md border border-gray-700 hidden dark:block" 
        />

      </a>
    </div>
  </section> <hr class="border-gray-200 dark:border-gray-800 max-w-4xl mx-auto mb-12" />

  <section class="max-w-4xl mx-auto px-6 py-10">
    <h2 class="text-3xl font-bold mb-6 font-heading">Testing</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
      To validate the design and manufacturing of the full fluid system, I served as Test Lead for our full system cold flow tests which are intended to provide invaluable data ahead of our Vertical Test Fire campaign and launch. Each successive cold flow comes with new challenges and problems to be solved, but through each test we learn new ways to improve our system and procedures which is vital for our future success.
    </p>

    <figure class="flex flex-col items-center mb-8">
      <img src="/portfolio/cold_flow.gif" alt="Cold Flow" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3" />
      <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">
        A cold flow test
      </figcaption>
    </figure>

    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
      Insert text here
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <figure class="flex flex-col items-center">
        <video src="/portfolio/vtf1.mp4" autoplay loop muted playsinline class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3"></video>
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">VTF1</figcaption>
      </figure>
      
      <figure class="flex flex-col items-center">
        <video src="/portfolio/vtf2.mp4" autoplay loop muted playsinline class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3"></video>
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">VTF2</figcaption>
      </figure>
      
      <figure class="flex flex-col items-center">
        <video src="/portfolio/vtf3.mp4" autoplay loop muted playsinline class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3"></video>
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">VTF3</figcaption>
      </figure>
      
      <figure class="flex flex-col items-center">
        <video src="/portfolio/vtf4.mp4" autoplay loop muted playsinline class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3"></video>
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">VTF4</figcaption>
      </figure>

      <figure class="flex flex-col items-center md:col-span-2 md:w-[calc(50%-1rem)] mx-auto">
        <video src="/portfolio/vtf5.mp4" autoplay loop muted playsinline class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3"></video>
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">VTF5</figcaption>
      </figure>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10 bg-gray-50 dark:bg-slate-900 rounded-2xl my-6 border border-gray-100 dark:border-gray-800">
    <h2 class="text-3xl font-bold mb-6 font-heading">Injector Design</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      I also helped design our engine's injector, which will be a triplet impinging injector. On the path towards the final injector design, we went through many iterations with different manifolding, element placement, and different impingement methods, including a like-doublet design. We finally settled on an impinging triplet design due to its simplicity of manifolding and its promise of increased performance. We had two main designs, one of which was intended for additive manufacturing and the other for traditional machining. I created an injector calculator to constrain the injector design parameters, such as orifice size and number, for both designs, and worked on the CAD for the additive injector design. While we ended up selecting the machined design, I still gained valuable experience in injector design and design for manufacturing. In addition to creating the CAD design for the injector, I made CFD simulations in STAR-CCM+ to validate injector parameters and to determine the pressure drop across the manifolding, which is something that cannot be easily calculated by hand. This helps to inform our feed system design and select appropriate propellant inlet pressures to maximize engine performance.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10">
    <h2 class="text-3xl font-bold mb-6 font-heading">Nozzle Design</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
      One of my main tasks on UCIRP was to design the nozzle for our engine, which will improve over the design of the previous engine, PTE. PTE's nozzle was severely overexpanded for the target flight altitude, and performance was lost as a result. I've researched conical and parabolic nozzle geometries in order to run CFD simulations in STAR-CCM+ to compare the different nozzle geometries expanded for different altitudes. I also created a MATLAB calculator to create the diverging geometry of the nozzle contour to be imported into the CFD simulations. The previous nozzle was designed for a target apogee of around 30,000 feet, which is far greater than the achieved apogee of about 10,000 feet, causing efficiency losses. Our next rocket is set to reach an apogee of around 16,000 feet, breaking the current record of 13,205 feet. This requires an optimally expanded nozzle to maximize thrust and efficiency.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <img src="/portfolio/nozzle_cfd_mach.gif" alt="Nozzle CFD GIF Mach" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700" />
      <img src="/portfolio/nozzle_cfd_temp.gif" alt="Nozzle CFD GIF Temperature" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700" />
    </div>

    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
      My MATLAB nozzle calculator takes inputs of throat and nozzle radius and outputs a set of points that follow a parabolic nozzle contour which is imported into STAR-CCM+ for analysis or Siemens NX to create the CAD for the nozzle. The contour is designed to improve the efficiency and thrust of the engine by better controlling the flow through the diverging portion of the nozzle.
    </p>

    <figure class="flex flex-col items-center">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-3 w-full">
        <img src="/portfolio/nozzle_cad.png" alt="Nozzle CAD" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700" />
        <img src="/portfolio/nozzle_cross_section.png" alt="Nozzle Cross Section" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700" />
      </div>
      <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">
        Graphite parabolic nozzle design in NX
      </figcaption>
    </figure>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10 bg-gray-50 dark:bg-slate-900 rounded-2xl my-6 mb-20 border border-gray-100 dark:border-gray-800">
    <h2 class="text-3xl font-bold mb-6 font-heading">Propellant Tank Design</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
      I've also helped design MOCH4's propellant tanks. Throughout the design phase, I researched and compared separate, common dome, and coaxial propellant tank designs before settling on separate tanks as the simplest option while allowing for vital feed system components to be placed in the inter-tank structure. After deciding on this design, I did calculations to determine the required thickness of the tanks while accounting for tank pressure, compressive stress, and shock force, ultimately determining that the critical load case for the tanks is pressure at launch. I then created the tanks in NX to be sent for manufacture.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <figure class="flex flex-col items-center">
        <img src="/portfolio/propellant_tank_cad.png" alt="Tank CAD" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3" />
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">
          Propellant tank CAD
        </figcaption>
      </figure>
      <figure class="flex flex-col items-center">
        <img src="/portfolio/propellant_tank_real.jpeg" alt="Tank Real" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3" />
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">
          Fully manufactured propellant tanks
        </figcaption>
      </figure>
    </div>
  </section>

</Layout>
