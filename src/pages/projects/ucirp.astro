    <h3 class="text-2xl font-bold mb-4 font-heading">Machining Shenanigans</h3>
    
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
      Insert text here
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-4">
      <figure class="flex flex-col items-center">
        <img src="/portfolio/shenanigans_1.jpeg" alt="Shenanigans 1" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3" />
        <figcaption class="text-sm text-gray-500 dark:text-gray-400 text-center italic px-2">Milling 9" stock into 7" round</figcaption>
      </figure>
      <figure class="flex flex-col items-center">
        <img src="/portfolio/shenanigans_2.jpeg" alt="Shenanigans 2" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 mb-3" />
