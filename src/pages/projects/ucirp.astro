---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'UCIRP',
};
---

<Layout metadata={metadata}>
<section class="relative h-[70vh] flex items-center justify-center overflow-hidden">
    <img 
      src="/portfolio/vtf_background.gif" 
      alt="Rocket Hot Fire Test" 
      class="absolute inset-0 w-full h-full object-cover -z-10"
    />
    <div class="absolute inset-0 bg-black/60 -z-10"></div>
    
    <h1 class="text-5xl md:text-7xl font-bold text-white tracking-wide text-center font-heading drop-shadow-lg">
      UCI Rocket Project
    </h1>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16 flex flex-col md:flex-row items-center gap-10">
    <div class="flex-1">
      <h2 class="text-3xl font-bold mb-4 font-heading">My Role</h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        I'm currently one of the Chief Engineers and Test Director for the project, where I have ownership over the propulsion system from a system level. I was previously the Lead Propulsion Engineer and Test Lead, where I owned engine design and manufacturing, particularly as it pertains to the nozzle and injector.
      </p>
    </div>
    
    <div class="flex-shrink-0">
      <a href="https://rocket.eng.uci.edu" target="_blank" class="block hover:scale-105 transition duration-300" aria-label="UCI Rocket Project Website">
        <img src="/portfolio/ucirp-logo.png" alt="UCI Rocket Project Logo" class="w-40 h-40 object-contain rounded-xl shadow-md border border-gray-100 dark:border-gray-800 bg-white" />
      </a>
    </div>
  </section>

  <hr class="border-gray-200 dark:border-gray-800 max-w-4xl mx-auto mb-12" />

  <section class="max-w-4xl mx-auto px-6 py-10">
    <h2 class="text-3xl font-bold mb-6 font-heading">Testing</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      [Drop in your details about test stands, data acquisition, cold flows, or hot fires here.]
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10 bg-gray-50 dark:bg-slate-900 rounded-2xl my-6 border border-gray-100 dark:border-gray-800">
    <h2 class="text-3xl font-bold mb-6 font-heading">Injector Design</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      [Details on pintle vs. impinging, pressure drops, manifolding, and machining tolerances.]
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10">
    <h2 class="text-3xl font-bold mb-6 font-heading">Nozzle Design</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      [Details on expansion ratios, contour generation, thermal analysis, and ablation/cooling strategies.]
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10 bg-gray-50 dark:bg-slate-900 rounded-2xl my-6 mb-20 border border-gray-100 dark:border-gray-800">
    <h2 class="text-3xl font-bold mb-6 font-heading">Propellant Tank Design</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      [Details on operating pressures, material selection, bulkheads, and fluid system routing.]
    </p>
  </section>
</Layout>
