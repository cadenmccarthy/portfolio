    <figure class="flex flex-col items-center mb-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-3 w-full">
        <img src="/portfolio/dwg_1.png" alt="Drawing 1" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700" />
        <img src="/portfolio/dwg_2.png" alt="Drawing 2" class="w-full h-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700" />
