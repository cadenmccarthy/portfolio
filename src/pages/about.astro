---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Me',
};
---

<Layout metadata={metadata}>
<div class="max-w-3xl mx-auto px-4 sm:px-6 pt-16 pb-8 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-6 font-heading">About Me</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
      Hi! My name is Caden and I'm a fourth-year aerospace engineering student at UC Irvine. I have a deep passion for spaceflight and have always been fascinated by rockets and engineering in general. I'm currently the chief engineer for the UCI Rocket Project. I'm a space nerd through-and-through and love spending my time learning about rockets! I strive to improve humanity's access to space and look forward to contributing to the aerospace industry. Outside of engineering, I'm an avid cellist and love hiking.
    </p>
    
    <div class="flex justify-center gap-6 mt-4 items-center">
      <a href="https://linkedin.com/in/caden-mccarthy" target="_blank" class="text-[#0a66c2] hover:text-blue-800 transition transform hover:scale-110" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
      </a>

      <a href="https://linktree.com/cadenmccarthy" target="_blank" class="text-[#43E660] hover:text-[#2da642] transition transform hover:scale-110 flex items-center justify-center" aria-label="Linktree">
        <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" viewBox="-2 -2 28 28" fill="currentColor">
          <path d="M13.736 12.32L17.848 8.134 15.65 5.922l-3.65 3.714V0h-2.95v9.636L5.4 5.922 3.202 8.134l4.112 4.186-4.908 4.996h4.524v5.48h2.95v-5.48h4.524l-4.908-4.996z" />
        </svg>
      </a>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
    <div class="grid grid-cols-2 gap-4 md:gap-6 items-start">
      <img src="/portfolio/about1.jpg" alt="About Me 1" class="w-full h-auto rounded-xl shadow-lg" />
      <img src="/portfolio/about4.jpg" alt="About Me 4" class="w-full h-auto rounded-xl shadow-lg" />
      <img src="/portfolio/about2.jpg" alt="About Me 2" class="w-full h-auto rounded-xl shadow-lg" />
      <img src="/portfolio/about3.jpeg" alt="About Me 3" class="w-full h-auto rounded-xl shadow-lg" />
    </div>
  </div>
</Layout>
