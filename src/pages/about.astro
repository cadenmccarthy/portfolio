---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Me',
};
---

<Layout metadata={metadata}>
<div class="max-w-3xl mx-auto px-4 sm:px-6 pt-16 pb-8 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-6 font-heading">About Me</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
      Hi, I'm Caden! I am an Aerospace Engineering student at UC Irvine with a passion for propulsion, orbital mechanics, and turning math into flying hardware. When I'm not in the lab or running simulations, you can usually find me [insert a fun hobby or interest here].
    </p>
    
    <div class="flex justify-center gap-4">
      <a href="https://linkedin.com/in/caden-mccarthy" target="_blank" class="px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg shadow-md hover:bg-blue-700 transition">
        LinkedIn
      </a>
      <a href="https://linktree.com/cadenmccarthy" target="_blank" class="px-6 py-3 bg-gray-800 text-white font-semibold rounded-lg shadow-md hover:bg-gray-900 transition dark:bg-gray-200 dark:text-gray-900 dark:hover:bg-gray-300">
        Linktree
      </a>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <img src="/portfolio/about1.jpg" alt="About Me 1" class="w-full h-80 object-cover rounded-xl shadow-lg transition hover:scale-[1.02] duration-300" />
      <img src="/portfolio/about2.jpg" alt="About Me 2" class="w-full h-80 object-cover rounded-xl shadow-lg transition hover:scale-[1.02] duration-300" />
      <img src="/portfolio/about3.jpg" alt="About Me 3" class="w-full h-80 object-cover rounded-xl shadow-lg transition hover:scale-[1.02] duration-300" />
      <img src="/portfolio/about4.jpg" alt="About Me 4" class="w-full h-80 object-cover rounded-xl shadow-lg transition hover:scale-[1.02] duration-300" />
    </div>
  </div>
</Layout>
