---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import bgImage from '~/assets/images/MOCH4_wide.jpg';

const metadata = {
  title: 'Portfolio',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

<Hero
  actions={[
    {
      variant: 'primary',
      text: 'Resume',
      href: '/portfolio/resume.pdf',
      target: '_blank',
      icon: 'tabler:download',
    },
  ]}
>
  <Fragment slot="title">
    Caden McCarthy
  </Fragment>

  <Fragment slot="subtitle">
    Aerospace Engineering Student at UC Irvine
  </Fragment>

  <Fragment slot="bg">
    <div class="absolute inset-0">
      <img 
        src={bgImage.src} 
        alt="Background" 
        class="w-full h-full object-cover opacity-30 dark:opacity-40"
      />
    </div>
  </Fragment>
</Hero>

<section class="max-w-5xl mx-auto px-6 pt-16 pb-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4 text-center">
      Engineering Projects
    </h2>
    <p class="text-lg text-gray-600 dark:text-gray-400">
      Click on any of the images below to learn more!
    </p>
  </section>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    
    <div class="flex flex-col items-center text-center">
      <a href="/portfolio/projects/ucirp" class="block">
        <img src="/portfolio/ucirp_logo_blue.png" alt="UCIRP Logo" class="w-full h-64 object-contain rounded-lg shadow-md mb-4 transition hover:scale-105 duration-300" />
        <h3 class="text-xl font-bold mb-2 hover:text-blue-600 transition">UC Irvine Rocket Project, Liquids Team</h3>
      </a>
      <p class="text-gray-600 dark:text-gray-400">Chief Engineer & Test Director</p>
    </div>

    <div class="flex flex-col items-center text-center">
      <a href="/portfolio/projects/orbital_mechanics" class="block">
        <img src="/portfolio/trajectory.gif" alt="Orbital Mechanics" class="w-full h-64 object-contain rounded-lg shadow-md mb-4 transition hover:scale-105 duration-300" />
        <h3 class="text-xl font-bold mb-2 hover:text-blue-600 transition">Orbital Mechanics Project</h3>
      </a>
      <p class="text-gray-600 dark:text-gray-400">Personal Project</p>
    </div>

    <div class="flex flex-col items-center text-center">
      <a href="/portfolio/projects/fwmav" class="block">
        <img src="/portfolio/fwmav_logo.png" alt="FWMAV Logo" class="w-full h-64 object-contain rounded-lg shadow-md mb-4 transition hover:scale-105 duration-300" />
        <h3 class="text-xl font-bold mb-2 hover:text-blue-600 transition">Flapping-Wing Micro Air Vehicle Design Project</h3>
      </a>
      <p class="text-gray-600 dark:text-gray-400">Beta Subteam</p>
    </div>

    <div class="flex flex-col items-center text-center">
      <a href="/portfolio/projects/other" class="block">
        <img src="/portfolio/merlin_engine.png" alt="Merlin Engine" class="w-full h-64 object-contain rounded-lg shadow-md mb-4 transition hover:scale-105 duration-300" />
        <h3 class="text-xl font-bold mb-2 hover:text-blue-600 transition">Other Projects</h3>
      </a>
      <p class="text-gray-600 dark:text-gray-400">Miscellaneous engineering projects</p>
    </div>

  </div>
</div>

<section class="max-w-5xl mx-auto px-6 py-16 mt-10 border-t border-gray-200 dark:border-gray-800">
    <h2 class="text-3xl md:text-4xl font-bold font-heading mb-2 text-center">
      SpaceX Internship
    </h2>
    
    <p class="text-lg text-gray-600 dark:text-gray-400 text-center font-medium mb-10">
      Starship Stage Structures Design Intern
    </p>
    
    <div class="flex flex-col items-center">
      <img 
        src="/portfolio/spacex_internship.jpg" 
        alt="SpaceX Photo" 
        class="w-full h-auto max-w-4xl rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 mb-8 object-cover" 
      />
      
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-4xl">
        During the summer of 2025, I worked at Starbase, TX as a Starship Stage Structures Design Intern. On the ship structures team, I designed large coupon panels to qualify barrel circumferential and vertical seams, pushing them through build and test to compare failure loads with predicted loads in FEM. I also worked on the design for the common dome LOX header feedline passthrough doubler, where I designed a doubler for the dome and ran analysis in ANSA/Abaqus with various flight loads. After closing analysis, I released the part to be installed on the vehicle. I also had the privilege of watching Starship Flight 10 from outside the factory, which was one of the most memorable and exciting moments of my life!
      </p>
    </div>
  </section>
